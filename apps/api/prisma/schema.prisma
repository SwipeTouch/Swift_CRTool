// Swipetouch CRMS — MySQL schema
// Docs: ../../../docs/design/02-DATABASE-DESIGN.md

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  APPROVER
  CS_MEMBER
  ADMIN
}

enum OrganizationStatus {
  active
  inactive
}

enum ChangeRequestStatus {
  PENDING_APPROVAL
  APPROVED_ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
  CLOSED
}

enum ChangeRequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CommentVisibility {
  INTERNAL
  CLIENT_VISIBLE
}

enum ExternalTicketSystem {
  JIRA
  OSTICKET
  OTHER
}

enum NotificationStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RETURNED_FOR_REASSIGN
  ASSIGNED
}

model Organization {
  id                String             @id @default(uuid())
  name              String             @db.VarChar(255)
  code              String             @unique @db.VarChar(50)
  segment           String             @default("mid-market") @db.VarChar(50)
  country           String             @default("India") @db.VarChar(100)
  city              String?            @db.VarChar(100)
  address           String?            @db.Text
  contactPhone      String?            @map("contact_phone") @db.VarChar(30)
  contactEmail      String?            @map("contact_email") @db.VarChar(255)
  primaryContactName String?           @map("primary_contact_name") @db.VarChar(150)
  slaDays           Int                @default(14) @map("sla_days")
  status            OrganizationStatus @default(active)
  defaultApproverId String?            @map("default_approver_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  defaultApprover User?            @relation("OrgDefaultApprover", fields: [defaultApproverId], references: [id], onDelete: SetNull)
  users           User[]
  changeRequests  ChangeRequest[]

  @@index([status])
  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  role           UserRole
  organizationId String?  @map("organization_id")
  fullName           String   @map("full_name") @db.VarChar(150)
  isDesignatedRaiser Boolean  @default(false) @map("is_designated_raiser")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  orgsAsDefaultApprover Organization[] @relation("OrgDefaultApprover")
  changeRequestsRaised  ChangeRequest[] @relation("CrRequestedBy")
  changeRequestsApproved ChangeRequest[] @relation("CrApprover")
  changeRequestsAssigned ChangeRequest[] @relation("CrAssignedStaff")
  workflowLogs          WorkflowLog[]
  comments              CrComment[]
  notifications         Notification[]
  notificationsActed    Notification[] @relation("NotificationActedBy")

  @@index([organizationId])
  @@index([role, isActive])
  @@map("system_users")
}

model ChangeRequest {
  id              String                @id @default(uuid())
  organizationId  String                @map("organization_id")
  requestedById   String                @map("requested_by_id")
  approverId      String?               @map("approver_id")
  assignedStaffId String?               @map("assigned_staff_id")
  title           String                @db.VarChar(255)
  description     String                @db.Text
  moduleAffected  String                @map("module_affected") @db.VarChar(100)
  status          ChangeRequestStatus   @default(PENDING_APPROVAL)
  priority        ChangeRequestPriority @default(MEDIUM)
  rejectionReason String?               @map("rejection_reason") @db.Text
  approvedAt      DateTime?             @map("approved_at")
  assignedAt      DateTime?             @map("assigned_at")
  resolvedAt      DateTime?             @map("resolved_at")
  closedAt        DateTime?             @map("closed_at")
  slaDueAt        DateTime?             @map("sla_due_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  requestedBy    User                 @relation("CrRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  approver       User?                @relation("CrApprover", fields: [approverId], references: [id], onDelete: SetNull)
  assignedStaff  User?                @relation("CrAssignedStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  workflowLogs   WorkflowLog[]
  comments       CrComment[]
  externalTickets ExternalTicketLink[]
  notifications  Notification[]

  @@index([organizationId, createdAt])
  @@index([status])
  @@index([assignedStaffId, status])
  @@map("change_requests")
}

model WorkflowLog {
  id              String   @id @default(uuid())
  changeRequestId String   @map("change_request_id")
  triggeredById   String   @map("triggered_by_id")
  previousStatus  String?  @map("previous_status") @db.VarChar(50)
  newStatus       String   @map("new_status") @db.VarChar(50)
  actionNote      String?  @map("action_note") @db.Text
  loggedAt        DateTime @default(now()) @map("logged_at")

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  triggeredBy   User          @relation(fields: [triggeredById], references: [id], onDelete: Restrict)

  @@index([changeRequestId, loggedAt])
  @@map("workflow_logs")
}

model CrComment {
  id              String            @id @default(uuid())
  changeRequestId String            @map("change_request_id")
  authorId        String            @map("author_id")
  content         String            @db.Text
  visibility      CommentVisibility @default(INTERNAL)
  createdAt       DateTime          @default(now()) @map("created_at")

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([changeRequestId, createdAt])
  @@map("cr_comments")
}

model ExternalTicketLink {
  id              String               @id @default(uuid())
  changeRequestId String               @map("change_request_id")
  system          ExternalTicketSystem
  externalId      String               @map("external_id") @db.VarChar(100)
  url             String?              @db.VarChar(500)
  linkedById      String               @map("linked_by_id")
  createdAt       DateTime             @default(now()) @map("created_at")

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@map("external_ticket_links")
}

model Notification {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  changeRequestId String             @map("change_request_id")
  status          NotificationStatus   @default(PENDING_APPROVAL)
  isRead          Boolean              @default(false) @map("is_read")
  actedById       String?              @map("acted_by_id")
  actedAt         DateTime?            @map("acted_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  actedBy       User?         @relation("NotificationActedBy", fields: [actedById], references: [id], onDelete: SetNull)

  @@unique([userId, changeRequestId])
  @@index([userId, status, isRead])
  @@index([changeRequestId])
  @@map("notifications")
}
